pipeline {
    agent any
    stages {
        stage('Git-Pull') {
            steps {
                git branch: 'devops', url: 'https://github.com/SanjayTomar22/EasyCRUD.git'
            }
        }
        stage('Build') {
            steps {
               sh '''cd backend
                    mvn clean package -DskipTests '''
            }
        }
        stage('Test') {
            steps {
                    withSonarQubeEnv(installationName: sonarqube credentialsId: 'sonar') {
                    sh '''cd backend
                        mvn  sonar:sonar \\\\
                      -Dsonar.projectKey=studentapp \\\\
                     '''
                }
                
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploy Success'
            }
        }
    }
}
