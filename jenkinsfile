pipeline {
    agent any
    stages {
        stage('Git-Pull') {
            steps {
                git branch: 'devops', url: 'https://github.com/SanjayTomar22/EasyCRUD.git'
            }
        }
        stage('Build') {
            steps {
               sh '''cd backend
                    mvn clean package -DskipTests '''
            }
        }
        stage('Test') {
            steps {
                sh '''cd backend
                        mvn  sonar:sonar \\\\
                      -Dsonar.projectKey=studentapp \\\\
                      -Dsonar.projectName=\\\'studentapp\\\' \\\\
                      -Dsonar.host.url=http://15.152.116.133:9000 \\\\
                      -Dsonar.token=sqp_8e5b1367ec4aa4993d8e6ad889253022b0da289d'''
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploy Success'
            }
        }
    }
}
